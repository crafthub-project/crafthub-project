# CraftHub — Environment Variables
# Copy this file to .env.local for local overrides

# ── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crafthub_db
DB_USER=root
DB_PASSWORD=root

# Full connection string (for ORMs like Prisma / Sequelize / Drizzle)
DATABASE_URL=mysql://root:root@localhost:3306/crafthub_db

# ── App ─────────────────────────────────────────────────────
VITE_APP_NAME=CraftHub
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API base URL (update to your backend when deployed)
VITE_API_BASE_URL=http://localhost:3001/api

# ── Auth ────────────────────────────────────────────────────
# Change these secrets before deploying to production
JWT_SECRET=crafthub_jwt_secret_change_me_in_production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── Storage ─────────────────────────────────────────────────
# For file uploads (certificates, product images)
VITE_UPLOAD_MAX_MB=5

# ── Email (optional — for certificate delivery) ─────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
