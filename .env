# ============================================================
# CraftHub Platform — Environment Variables
# ============================================================
# Copy this file to .env.local for local overrides.
# NEVER commit secrets to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
VITE_APP_NAME=CraftHub
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ── MySQL Database Connection ────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crafthub_db
DB_USER=root
DB_PASSWORD=root
DB_CONNECTION_LIMIT=10
DB_SSL=false

# Database URL (alternative DSN format for ORMs like Prisma / Drizzle)
DATABASE_URL=mysql://root:root@localhost:3306/crafthub_db

# ── API / Backend ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api/v1

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=crafthub_jwt_secret_change_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── File Uploads ─────────────────────────────────────────────
VITE_UPLOAD_MAX_SIZE_MB=10
UPLOAD_DEST=./uploads

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@crafthub.ug
SMTP_PASS=your_smtp_password_here
EMAIL_FROM=CraftHub <noreply@crafthub.ug>

# ── SMS / OTP (Africa's Talking) ─────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=CraftHub

# ── Storage (local or S3-compatible) ─────────────────────────
STORAGE_DRIVER=local
# S3_BUCKET=crafthub-assets
# S3_REGION=af-south-1
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key

# ── Feature Flags ────────────────────────────────────────────
VITE_ENABLE_CERTIFICATES=true
VITE_ENABLE_BADGES=true
VITE_ENABLE_MARKETPLACE=true
VITE_ENABLE_BABY_HEALTH=true
VITE_ENABLE_OFFLINE_MODE=true
